// Generate ast-grep rules to migrate from the old `AstBuilder` to the new builder methods
// defined on AST types.
//
// Reads:
// * `generated/mappings.json` - generated by `AstBuilderGenerator` (`tasks/ast_tools`).
// * `generated/shorten_mappings.json` - generated by `AstBuilderGenerator`; structural mappings for
//   the post-migration "shortening" pass (box-collapse / variant-wrap / inherited-from).
// * `custom_mappings.json` - hand-written mappings for methods not emitted by codegen.
//
// Writes:
// * `generated/rules.yml` - ast-grep rules: one per builder method (migration), plus the
//   "shortening" rules that collapse verbose new-builder shapes into their shorthand equivalents.
//
// Each rule rewrites a call on the old builder to a call to the new method, appending the
// accessor (the base of the `<accessor>.ast` receiver) as the final argument:
//
//   self.ast.null_literal(span)             ->  NullLiteral::new(span, self)
//   p.ast.alloc_object_expression(span, x)  ->  ObjectExpression::boxed(span, x, p)
//   self.ast.number_0()                     ->  Expression::new_number_0(self)
//
// Run with:  `node tasks/ast_builder_migration/generate_rules.mts`
// Then apply with the `run.sh` command it prints.

// oxlint-disable no-console

import { readFileSync, writeFileSync } from "node:fs";
import { join } from "node:path";

const DIR = import.meta.dirname;

// ─────────────────────────────────────────────────────────────────────────────
// Configuration
//
// These consts capture the conventions that tend to differ between Oxc and
// downstream consumers of the Oxc crates. The defaults reproduce Oxc's own rules
// exactly; change them to match your project, then re-run this script.
// ─────────────────────────────────────────────────────────────────────────────

// (1) Names of the arena primitive types.
//
// The custom mappings (and the box-collapse rule) refer to these by Oxc's names.
// If your project imports them under different names, map Oxc's name -> yours here,
// e.g. `{ ArenaVec: "Vec" }`, `{ ArenaVec: "OxcVec" }`,
// or `{ ArenaVec: "oxc_allocator::Vec" }`.
// Only these exact type names are renamed.
// AST type names (`Expression`, `NullLiteral`, ...) are always left untouched.
const PRIMITIVE_TYPES: Record<string, string> = {
  ArenaBox: "ArenaBox",
  ArenaVec: "ArenaVec",
  Ident: "Ident",
  Str: "Str",
};

// (2) The field the old `AstBuilder` is reached through.
//
// Oxc writes `self.ast.null_literal(span)`, so the field is `ast` and the rules
// match `$ACCESSOR.ast.<method>(...)`. If your code is
// `ctx.builder.null_literal(span)`, set this to `"builder"`.
//
// If you hold the `AstBuilder` (or `Allocator`) directly in a variable - so the
// call is `ast.null_literal(span)` with no field access - set this to `""`.
// The rules then match `$ACCESSOR.<method>(...)`, where `$ACCESSOR` is the variable.
const AST_BUILDER_FIELD = "ast";

// (3) Whether to pass the trailing accessor/allocator argument by reference.
//
// Each migration appends the accessor as the new method's final argument. Oxc
// appends it bare (`NullLiteral::new(span, self)`) because `self` implements
// `GetAstBuilder`/`GetAllocator`, so leave this `false`. If the accessor is a
// variable holding the builder/allocator that the new methods take by reference,
// set this to `true` so the fix becomes `NullLiteral::new(span, &ast)`.
const ACCESSOR_BY_REF = false;

// (4) Module path the AST types are referred to through.
//
// All rules use bare AST type names (`Expression::new_*`, `NullLiteral::new`, ...),
// matching Oxc's own `use oxc_ast::ast::*;`. If your code reaches the types through
// a module alias instead (as `oxc_react_compiler` does, via `use oxc_ast::ast as oxc;`
// -> `oxc::Expression`), set this to that prefix *including the trailing `::`*,
// e.g. `"oxc::"`. It is prepended to every AST type name (but not to the
// arena primitives above, which carry their own paths via `PRIMITIVE_TYPES`).
const AST_TYPE_PREFIX = "";

// ─────────────────────────────────────────────────────────────────────────────
// Script body
// ─────────────────────────────────────────────────────────────────────────────

type CustomMappings = { mappings: Record<string, string>; zeroArg: string[] };

const generated: Record<string, string> = JSON.parse(
  readFileSync(join(DIR, "generated", "mappings.json"), "utf8"),
);
const custom: CustomMappings = JSON.parse(readFileSync(join(DIR, "custom_mappings.json"), "utf8"));

// Structural mappings for the "shortening" pass, generated by `AstBuilderGenerator`. These collapse
// verbose new-builder call shapes into their shorthand equivalents (see `buildShortenRuleDoc`).
type ShortenMappings = {
  // `[T::new, T::boxed]`
  boxed: [string, string][];
  // `[enum, variant, inner builder path, ctor path]`
  variantWrap: [string, string, string, string][];
  // `[outer enum, inherited enum, ctor method name]`
  inheritedFrom: [string, string, string][];
};
const shorten: ShortenMappings = JSON.parse(
  readFileSync(join(DIR, "generated", "shorten_mappings.json"), "utf8"),
);

// Merge generated and custom mappings. The two sets are disjoint - custom mappings are for
// hand-written methods which codegen never emits - so an overlap signals a mistake.
const mappings: Record<string, string> = { ...generated };
for (const [oldName, newPath] of Object.entries(custom.mappings)) {
  if (oldName in mappings) {
    throw new Error(`Custom mapping \`${oldName}\` collides with a generated mapping`);
  }
  mappings[oldName] = newPath;
}

const zeroArg = new Set(custom.zeroArg);

// Build one ast-grep rule (a YAML document) per method, sorted by method name for a stable diff.
const migrationDocs = Object.keys(mappings)
  .sort()
  .map((oldName) => buildRuleDoc(oldName, qualifyType(mappings[oldName]), zeroArg.has(oldName)));

// Build the "shortening" rules from the structural mappings. Sorted by `id` for a stable diff.
const sanitize = (str: string) => str.replace(/[^A-Za-z0-9]+/g, "_");
const shortenDocs = [
  // box-collapse:  `ArenaBox::new_in(T::new($$$ARGS), $ALLOC)`  ->  `T::boxed($$$ARGS)`
  ...shorten.boxed.map(([newPath, boxedPath]) =>
    buildShortenRuleDoc(
      `box-collapse-${sanitize(boxedPath)}`,
      `${qualifyType("ArenaBox")}::new_in(${qualifyType(newPath)}($$$ARGS), $ALLOC)`,
      `${qualifyType(boxedPath)}($NOCOMMENT)`,
    ),
  ),
  // variant-wrap:  `E::Variant(Inner::boxed($$$ARGS))`  ->  `E::new_variant($$$ARGS)`
  ...shorten.variantWrap.map(([enumName, variant, innerPath, ctorPath]) =>
    buildShortenRuleDoc(
      `variant-wrap-${sanitize(ctorPath)}`,
      `${qualifyType(enumName)}::${variant}(${qualifyType(innerPath)}($$$ARGS))`,
      `${qualifyType(ctorPath)}($NOCOMMENT)`,
    ),
  ),
  // inherited-from:  `Outer::from(Inner::new_x($$$ARGS))`  ->  `Outer::new_x($$$ARGS)`
  ...shorten.inheritedFrom.map(([outer, inner, ctor]) =>
    buildShortenRuleDoc(
      `inherited-from-${sanitize(outer)}-${sanitize(inner)}-${sanitize(ctor)}`,
      `${qualifyType(outer)}::from(${qualifyType(inner)}::${ctor}($$$ARGS))`,
      `${qualifyType(outer)}::${ctor}($NOCOMMENT)`,
    ),
  ),
].sort();

const documents = [...migrationDocs, ...shortenDocs];

const header = "# Auto-generated by `generate_rules.mts`. DO NOT EDIT.\n";
const outPath = join(DIR, "generated", "rules.yml");
writeFileSync(outPath, header + documents.join("---\n"));

console.log(
  `Wrote ${documents.length} rules (${migrationDocs.length} migration, ${shortenDocs.length} shortening) to ${outPath}`,
);
console.log("\nApply with:\n  tasks/ast_builder_migration/run.sh <path>");

// Build a single ast-grep rule (one YAML document).
//
// The old builder is reached via `<accessor>.ast` in Oxc (e.g. `self.ast`, `p.ast`), where
// `<accessor>` (`self` / `p`) implements `GetAstBuilder`. The rule matches that access and appends
// `<accessor>` as the new method's final argument. Downstream consumers whose builder is reached
// by a different path adjust the `AST_BUILDER_FIELD` / `ACCESSOR_BY_REF` consts at the top of the
// file rather than editing the templates here.
//
// For methods with arguments, the fix appends `, $ACCESSOR` to the captured args. Two `transform`
// steps prepare the args so this is always valid:
//   1. `NOCOMMENT`: rewrite a trailing line comment on the last arg to a block comment, so the
//      appended `, $ACCESSOR` is not swallowed into the comment (e.g. `x, // c` -> `x /* c */`).
//   2. `CLEANARGS`: strip any trailing comma (common in rustfmt'd multi-line calls), else appending
//      `, $ACCESSOR` would yield a double comma.
// Zero-arg methods omit `$$$ARGS` entirely, else its empty expansion would leave a leading comma
// (`Type::method(, $ACCESSOR)`).
function buildRuleDoc(oldName: string, newPath: string, isZeroArg: boolean): string {
  // `JSON.stringify` yields a double-quoted scalar valid in YAML. `id`s must be unique - the old
  // method name already is.
  const q = (str: string) => JSON.stringify(str);
  // The receiver the builder is reached through (see `AST_BUILDER_FIELD`): `$ACCESSOR.ast` in Oxc,
  // or bare `$ACCESSOR` when the builder is held directly in a variable.
  const receiver = AST_BUILDER_FIELD ? `$ACCESSOR.${AST_BUILDER_FIELD}` : "$ACCESSOR";
  // The accessor appended as the new method's final argument (see `ACCESSOR_BY_REF`).
  const accessor = ACCESSOR_BY_REF ? "&$ACCESSOR" : "$ACCESSOR";
  const lines = [`id: ${oldName}`, `language: rust`, `rule:`];
  if (isZeroArg) {
    lines.push(
      `  pattern: ${q(`${receiver}.${oldName}()`)}`,
      `fix: ${q(`${newPath}(${accessor})`)}`,
    );
  } else {
    lines.push(
      `  pattern: ${q(`${receiver}.${oldName}($$$ARGS)`)}`,
      `transform:`,
      `  NOCOMMENT:`,
      `    replace:`,
      `      source: ${q("$$$ARGS")}`,
      `      replace: ${q(",\\s*//\\s*(.*)$")}`,
      `      by: ${q(" /* $1 */")}`,
      `  CLEANARGS:`,
      `    replace:`,
      `      source: ${q("$NOCOMMENT")}`,
      `      replace: ${q(",\\s*$")}`,
      `      by: ${q("")}`,
      `fix: ${q(`${newPath}($CLEANARGS, ${accessor})`)}`,
    );
  }
  return `${lines.join("\n")}\n`;
}

// Build a "shortening" rule (one YAML document) that collapses a verbose new-builder call shape into
// its shorthand equivalent, replaying the inner call's arguments (`$$$ARGS`) verbatim:
//
//   ArenaBox::new_in(VariableDeclaration::new(span, kind, ..., b), x)  // box-collapse
//     -> VariableDeclaration::boxed(span, kind, ..., b)
//   Statement::VariableDeclaration(VariableDeclaration::boxed(span, ..., b))  // variant-wrap
//     -> Statement::new_variable_declaration(span, ..., b)
//   Statement::from(Declaration::new_variable_declaration(span, ..., b))  // inherited-from
//     -> Statement::new_variable_declaration(span, ..., b)
//
// `pattern` captures the inner arguments as `$$$ARGS`; `fix` replays them as `$NOCOMMENT`. The
// `NOCOMMENT` transform rewrites a trailing line comment on the last argument to a block comment
// (e.g. `x, // c` -> `x /* c */`), so the replayed args stay valid when the closing `)` is pulled
// onto the comment's line. Unlike the migration rules nothing is appended, so no `CLEANARGS` step is
// needed - a trailing comma inside the parens is harmless.
//
// These rules are accessor-agnostic (they match only new-builder output shapes, never `<x>.ast`), so
// downstream consumers (e.g. Rolldown) can reuse them unchanged.
function buildShortenRuleDoc(id: string, pattern: string, fix: string): string {
  const q = (str: string) => JSON.stringify(str);
  return (
    [
      `id: ${id}`,
      `language: rust`,
      `rule:`,
      `  pattern: ${q(pattern)}`,
      `transform:`,
      `  NOCOMMENT:`,
      `    replace:`,
      `      source: ${q("$$$ARGS")}`,
      `      replace: ${q(",\\s*//\\s*(.*)$")}`,
      `      by: ${q(" /* $1 */")}`,
      `fix: ${q(fix)}`,
    ].join("\n") + "\n"
  );
}

// Apply the type-naming config to a type reference - either a bare type name (`Statement`) or a
// `Type::method` path (`NullLiteral::new`). An arena primitive (`PRIMITIVE_TYPES`) is renamed and
// left otherwise unqualified; any other (AST) type is prefixed with `AST_TYPE_PREFIX`. With the
// defaults both are no-ops, so the rules are byte-identical to Oxc's.
function qualifyType(typeRef: string): string {
  const idx = typeRef.indexOf("::");
  const head = idx === -1 ? typeRef : typeRef.slice(0, idx);
  const rest = idx === -1 ? "" : typeRef.slice(idx);
  const primitive = PRIMITIVE_TYPES[head];
  return primitive === undefined ? `${AST_TYPE_PREFIX}${head}${rest}` : `${primitive}${rest}`;
}
