{
  "compilerOptions": {
    "lib": ["ESNext"],
    "module": "Preserve",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "target": "ESNext",
    "strict": true,
    "skipLibCheck": true,
    "types": ["vitest/importMeta"]
  },
  "include": ["scripts", "conformance/*.ts", "src-js", "test/**/*.ts"],
  "exclude": ["test/**/fixtures"]
}
