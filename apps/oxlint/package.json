{
  "name": "oxlint-app",
  "version": "1.58.0",
  "private": true,
  "description": "Internal development package for oxlint. For the published package.json template, see `npm/oxlint/package.json`.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "imports": {
    "#oxlint": {
      "code": "./src-js/index.ts",
      "default": "./dist/index.js"
    },
    "#oxlint/plugins": {
      "code": "./src-js/plugins.ts",
      "default": "./dist-pkg-plugins/index.js"
    },
    "#oxlint/plugins-dev": {
      "code": "./src-js/plugins-dev.ts",
      "default": "./dist/plugins-dev.js"
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./plugins-dev": {
      "types": "./dist/plugins-dev.d.ts",
      "default": "./dist/plugins-dev.js"
    }
  },
  "scripts": {
    "build": "pnpm run build-napi-release && pnpm run build-js",
    "build-dev": "pnpm run build-napi && cross-env DEBUG=true pnpm run build-js",
    "build-test": "pnpm run build-napi-test && cross-env DEBUG=true pnpm run build-js",
    "setup:svelte-real-packages": "node --experimental-strip-types ./scripts/install-real-svelte-packages.ts",
    "setup:svelte-real-packages:latest-svelte": "node --experimental-strip-types ./scripts/install-real-svelte-packages.ts --profile latest-svelte",
    "check:svelte-real-packages": "node --experimental-strip-types ./scripts/check-real-svelte-packages.ts",
    "check:svelte-real-packages:latest-svelte": "node --experimental-strip-types ./scripts/check-real-svelte-packages.ts --profile latest-svelte",
    "report:svelte-real-packages": "node --experimental-strip-types ./scripts/report-real-svelte-packages.ts",
    "report:svelte-real-packages:latest-svelte": "node --experimental-strip-types ./scripts/report-real-svelte-packages.ts --profile latest-svelte",
    "annotate:svelte-real-packages": "node --experimental-strip-types ./scripts/annotate-real-svelte-packages.ts",
    "annotate:svelte-real-packages:latest-svelte": "node --experimental-strip-types ./scripts/annotate-real-svelte-packages.ts --profile latest-svelte",
    "clean:svelte-real-packages": "node --experimental-strip-types ./scripts/cleanup-real-svelte-packages.ts",
    "test:svelte-real-packages": "pnpm run check:svelte-real-packages && pnpm run test:svelte-real-packages:runtime && pnpm run test:svelte-real-packages:fixtures && pnpm run test:svelte-real-packages:smoke && pnpm run test:svelte-real-packages:lsp && pnpm run test:svelte-real-packages:lsp-smoke",
    "test:svelte-real-packages:managed": "node --experimental-strip-types ./scripts/run-real-svelte-package-tests.ts",
    "test:svelte-real-packages:latest-svelte": "node --experimental-strip-types ./scripts/run-real-svelte-package-tests.ts --profile latest-svelte",
    "test:svelte-real-packages:latest-svelte:debug": "cross-env OXLINT_SVELTE_REAL_PACKAGES_KEEP_ON_FAILURE=1 node --experimental-strip-types ./scripts/run-real-svelte-package-tests.ts --profile latest-svelte",
    "test:svelte-real-packages:debug": "cross-env OXLINT_SVELTE_REAL_PACKAGES_KEEP_ON_FAILURE=1 node --experimental-strip-types ./scripts/run-real-svelte-package-tests.ts",
    "test:svelte-real-packages:fresh": "pnpm run test:svelte-real-packages:managed",
    "build-conformance": "pnpm run build-napi-test && cross-env CONFORMANCE=true pnpm run build-js",
    "build-napi": "napi build --esm --platform --js ./bindings.js --dts ./bindings.d.ts --output-dir src-js --no-dts-cache",
    "build-napi-test": "pnpm run build-napi --features testing --profile coverage",
    "build-napi-release": "pnpm run build-napi --release --features allocator",
    "build-js": "node --experimental-strip-types scripts/build.ts",
    "generate-config-types": "node --experimental-strip-types scripts/generate-config-types.ts",
    "test": "vitest --dir ./test run",
    "init-conformance": "cd conformance; ./init.sh",
    "conformance": "cross-env NODE_DISABLE_COLORS=1 CONFORMANCE=true tsx --conditions=code ./conformance/src/index.ts",
    "test:svelte-real-packages:runtime": "cross-env OXLINT_SVELTE_REAL_PACKAGES_CI=1 vitest run ./test/real_svelte_parser_whole_file.test.ts ./test/real_svelte_plugin_whole_file.test.ts ./test/svelte_real_package_manifest.test.ts",
    "test:svelte-real-packages:fixtures": "cross-env OXLINT_SVELTE_REAL_PACKAGES_CI=1 vitest run ./test/svelte_real_package_e2e.test.ts",
    "test:svelte-real-packages:smoke": "cross-env OXLINT_SVELTE_REAL_PACKAGES_CI=1 vitest run ./test/svelte_real_package_smoke.test.ts",
    "test:svelte-real-packages:lsp": "cross-env OXLINT_SVELTE_REAL_PACKAGES_CI=1 vitest run ./test/lsp/real_svelte_package.test.ts",
    "test:svelte-real-packages:lsp-smoke": "cross-env OXLINT_SVELTE_REAL_PACKAGES_CI=1 vitest run ./test/lsp/real_svelte_package_smoke.test.ts"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "catalog:",
    "@babel/code-frame": "^7.28.6",
    "@napi-rs/cli": "catalog:",
    "@oxc-project/types": "^0.123.0",
    "@type-challenges/utils": "^0.1.1",
    "@types/babel__code-frame": "^7.27.0",
    "@types/esquery": "^1.5.4",
    "@types/estree": "^1.0.8",
    "@types/json-schema": "^7.0.15",
    "@types/json-stable-stringify-without-jsonify": "^1.0.2",
    "@types/node": "catalog:",
    "@types/serialize-javascript": "^5.0.4",
    "@typescript-eslint/parser": "^8.54.0",
    "@typescript-eslint/scope-manager": "^8.54.0",
    "ajv": "6.14.0",
    "cross-env": "catalog:",
    "eslint": "catalog:",
    "eslint-vitest-rule-tester": "^3.0.1",
    "esquery": "^1.6.0",
    "execa": "^9.6.0",
    "json-schema-to-typescript": "catalog:",
    "json-stable-stringify-without-jsonify": "^1.0.1",
    "oxc-parser": "^0.123.0",
    "rolldown": "catalog:",
    "serialize-javascript": "^7.0.4",
    "tsdown": "catalog:",
    "tsx": "^4.21.0",
    "type-fest": "^5.2.0",
    "vitest": "catalog:",
    "vscode-languageserver-protocol": "^3.17.5",
    "vscode-languageserver-textdocument": "^1.0.12"
  },
  "napi": {
    "binaryName": "oxlint",
    "packageName": "@oxlint/binding",
    "targets": [
      "aarch64-apple-darwin",
      "aarch64-linux-android",
      "aarch64-pc-windows-msvc",
      "aarch64-unknown-linux-gnu",
      "aarch64-unknown-linux-musl",
      "aarch64-unknown-linux-ohos",
      "armv7-linux-androideabi",
      "armv7-unknown-linux-gnueabihf",
      "armv7-unknown-linux-musleabihf",
      "i686-pc-windows-msvc",
      "powerpc64le-unknown-linux-gnu",
      "x86_64-apple-darwin",
      "x86_64-pc-windows-msvc",
      "x86_64-unknown-freebsd",
      "x86_64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl"
    ]
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
