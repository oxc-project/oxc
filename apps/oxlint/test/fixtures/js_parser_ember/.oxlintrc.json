{
  "rules": {
    "no-debugger": "error",
    "eqeqeq": "error",
    "no-unused-vars": "error"
  },
  "overrides": [
    {
      "files": ["**/*.{gjs,gts}"],
      "jsPlugins": ["eslint-plugin-ember"],
      "languageOptions": {
        "parser": "ember-eslint-parser"
      },
      "rules": {
        "ember/template-no-let-reference": "error"
      }
    }
  ]
}
