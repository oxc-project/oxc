//   added comma is a semantic no-op (`(x,)` is a single-element list in Sass).
@include container(
  $foo: (
    $bar,
    $baz,
  )
);
@include first-not-kv(a, $k: (1, 2));
@include first-kv(
  $k: (
    1,
    2,
  ),
  a
);
.a {
  color: fn(a, $k: (1, 2));
  border-color: fn(
    $k: (
      1,
