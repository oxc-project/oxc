==================== Input ====================
// Non-ASCII (Cyrillic) content in interpolated strings with embedded quotes
// must survive byte-for-byte (issue #24841); bytes were re-encoded as Latin-1.

@function write-error($value) {
  @error 'error with значение: "#{$value}"';
}

.a {
  content: 'значение "#{$v}"';
}

