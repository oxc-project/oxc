 5 в”Ӯ                       await doSomething()
 6 в”Ӯ                       expose({ /* ... */ })
   В·                       в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
