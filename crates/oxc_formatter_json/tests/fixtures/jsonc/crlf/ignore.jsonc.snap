  "a": 1,
  // prettier-ignore
  "b": {
    "c":   2
  },
  "d": [1, 2, 3],
}

-------------------------------------------------------
{ endOfLine: "crlf", printWidth: 80, variant: "jsonc" }
-------------------------------------------------------
