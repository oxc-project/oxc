  "a": 1,
  // prettier-ignore
  "b": {
    "c":   2
  },
  "d": [1, 2, 3],
}

------------------------------------------------------
{ endOfLine: "lf", printWidth: 100, variant: "jsonc" }
------------------------------------------------------
