// Fix 7: @typedef with blank line between tag+type+name and description

/**
 * @typedef {Object} MyType
 *
 * This is a description separated by a blank line from the typedef declaration.
 */
const a = 1;

/**
 * @param {string} name
 *
 * Description after blank line for a param tag.
 */
function withParamBlank(name) {}

/**
 * @typedef {import("./foo").Bar} AliasType
 *
 * An alias type with a blank line before its description that should wrap when the description is long enough to exceed the print width.
 */
const b = 2;

