==================== Input ====================
// Multiline arrays collapse when they fit
const collapsed = [
  1,
  2,
  3,
];
// Even arrays of objects that Prettier's heuristic would expand
const objects = [
  { a: 1 },
  { b: 2 },
];
const nested = [
  [1, 2],
  [3, 4],
];
// Arrays wider than printWidth still break
const wide = [
  "aaaaaaaaaaaaaaaaaaaa",
  "bbbbbbbbbbbbbbbbbbbb",
  "cccccccccccccccccccc",
  "dddddddddddddddddddd",
  "eeeeeeeeeeeeeeeeeeee",
];
// A trailing line comment still forces a break
const commented = [1, 2, // line
];

==================== Output ====================
