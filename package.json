{
  "name": "oxc",
  "private": true,
  "scripts": {
    "build": "vp run --workspace-concurrency=1 --filter \"./napi/*\" --filter \"./apps/*\" build",
    "build-dev": "vp run --workspace-concurrency=1 --filter \"./napi/*\" --filter \"./apps/*\" build-dev",
    "build-test": "vp run --workspace-concurrency=1 --filter \"./napi/*\" --filter \"./apps/*\" build-test",
    "build-wasm-dev": "vp run --workspace-concurrency=1 --filter \"./napi/*\" build-wasm-dev",
    "test": "vp run --workspace-concurrency=1 --filter \"./napi/*\" --filter \"./apps/*\" test",
    "fmt": "oxfmt -c oxfmtrc.jsonc",
    "lint": "oxlint -c oxlintrc.json --deny-warnings --report-unused-disable-directives"
  },
  "devDependencies": {
    "@napi-rs/cli": "catalog:",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.51.0",
    "oxlint-tsgolint": "0.19.0"
  },
  "packageManager": "pnpm@10.33.0"
}
