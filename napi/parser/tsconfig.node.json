{
  "compilerOptions": {
    "lib": ["ESNext"],
    "module": "Preserve",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "target": "ESNext",
    "allowImportingTsExtensions": true,
    "skipLibCheck": true,
    "noImplicitAny": true,
    "strict": false
  },
  "exclude": ["test-browser", "vitest.config.browser.ts"]
}
